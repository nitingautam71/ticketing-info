// Prisma schema for Ticketing-Info.
//
// Postgres (Neon) is the datastore for both local dev and production — same
// DATABASE_URL in .env.local and in Vercel's production env vars. Consider
// splitting to a separate Neon branch for dev once there's real prod traffic.
//
// Pinned to prisma/@prisma-client 6.19.3 (see package.json) on purpose: Prisma 7
// removed schema-level `datasource url` support (requires a driver-adapter
// rewrite in prisma.config.ts instead), which breaks `db push`/`generate` for
// this file as written. Don't bump past 6.x without adding that adapter config.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Backs human-readable sequential display IDs (LD-/BK-/QT-YYYYMMDD-NNNNNN).
// `id` is the full date-scoped key (e.g. "LD-20260711") so the increment is a
// single atomic UPSERT — safe under concurrent requests, unlike counting
// existing rows (which races: two requests can read the same count before
// either commits).
model DailyCounter {
  id    String @id
  count Int    @default(0)
}

enum Vertical {
  flight
  hotel
  cruise
  train
  car
  transfer
  insurance
  package
  visa
}

enum ContactMethod {
  call
  whatsapp
  callback
  form
  email
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
}

// Simple admin-managed roster for assigning leads/tasks to a named consultant.
// Not a login identity yet — everyone still authenticates with the shared
// ADMIN_PASSWORD gate. Upgrade to real per-agent accounts (own password, own
// session) when there's more than one person actually logging into /admin.
model Agent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  name      String
  email     String   @unique
  phone     String?
  active    Boolean  @default(true)

  assignedLeads    Lead[]
  assignedBookings Booking[]
  assignedTasks    Task[]
  communications   CommunicationLog[]
}

enum LeadSource {
  website
  phone
  whatsapp
  facebook
  instagram
  google_ads
  email
  referral
}

enum LeadStage {
  new
  assigned
  contacted
  follow_up
  quotation_sent
  negotiating
  waiting_for_documents
  payment_pending
  paid
  ticketed
  completed
  cancelled
  lost
  refunded
}

enum LeadPriority {
  low
  normal
  high
  urgent
}

// A qualified lead generated from any search/detail page — the core MVP conversion event.
model Lead {
  id            String        @id @default(cuid())
  displayId     String        @unique // e.g. LD-20260711-000154
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  vertical      Vertical
  contactMethod ContactMethod
  source        LeadSource    @default(website)
  stage         LeadStage     @default(new)
  priority      LeadPriority  @default(normal)

  name  String
  email String?
  phone String?

  message    String?
  notes      String?
  sourcePage String?
  payload    Json? // the search result / item the lead was raised against

  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?

  assignedAgent   Agent?  @relation(fields: [assignedAgentId], references: [id])
  assignedAgentId String?

  bookings       Booking[]
  quotations     Quotation[]
  tasks          Task[]
  communications CommunicationLog[]

  @@index([stage])
  @@index([vertical])
  @@index([createdAt])
  @@index([assignedAgentId])
}

model Customer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  email    String  @unique
  phone    String?
  whatsapp String?

  gender         String?
  dob            DateTime?
  nationality    String?
  passportNumber String?
  passportExpiry DateTime?
  visaStatus     String?

  addressStreet  String?
  addressCity    String?
  addressCountry String?
  addressZip     String?

  // { seatPreference, mealPreference, preferredAirlines: [], preferredHotelBrands: [],
  //   frequentFlyerNumbers: [{airline, number}], loyaltyMemberships: [{program, number}] }
  preferences Json?

  totalSpend Float   @default(0)
  notes      String?

  leads          Lead[]
  bookings       Booking[]
  passengers     Passenger[]
  quotations     Quotation[]
  documents      Document[]
  communications CommunicationLog[]
}

// A booking request/confirmation. Since MVP has no online payment, these start
// as "pending" the moment a lead is captured and are moved to "confirmed" by
// an admin once payment/ticketing is settled offline (phone, WhatsApp, bank transfer).
model Booking {
  id        String        @id @default(cuid())
  displayId String        @unique // e.g. BK-20260711-000042
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  vertical  Vertical
  status    BookingStatus @default(pending)

  title         String
  subtitle      String?
  priceEstimate Float?
  travelDate    String?
  details       Json?

  // Flight-specific fields — kept flat since a booking is normally one primary
  // itinerary; per-segment detail (layovers, terminals, fare basis) lives in
  // `details` Json until segment-level UI justifies a dedicated model.
  airline      String?
  flightNumber String?
  pnr          String?
  ticketNumber String?
  bookingClass String?
  fareBasis    String?

  lead       Lead?     @relation(fields: [leadId], references: [id])
  leadId     String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?

  assignedAgent   Agent?  @relation(fields: [assignedAgentId], references: [id])
  assignedAgentId String?

  passengers         Passenger[]
  payments           Payment[]
  cardAuthorizations CardAuthorization[]
  documents          Document[]
  communications     CommunicationLog[]
  tasks              Task[]

  @@index([status])
  @@index([vertical])
  @@index([assignedAgentId])
}

model Passenger {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId String

  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?

  name           String
  dob            DateTime?
  gender         String?
  nationality    String?
  passportNumber String?
  passportExpiry DateTime?
  visaDetails    String?

  mealPreference       String?
  seatPreference       String?
  specialAssistance    String?
  wheelchair           Boolean @default(false)
  infantAssociatedWith String? // name of the adult passenger this infant travels with

  @@index([bookingId])
}

// A price quote that can be converted into a Booking once accepted.
model Quotation {
  id        String   @id @default(cuid())
  displayId String   @unique // e.g. QT-20260711-000019
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead       Lead?     @relation(fields: [leadId], references: [id])
  leadId     String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?

  // [{ description: string, amount: number }]
  lineItems Json
  subtotal  Float
  taxes     Float @default(0)
  discount  Float @default(0)
  total     Float

  status               String    @default("draft") // draft | sent | accepted | rejected | expired
  validUntil           DateTime?
  convertedToBookingId String?
}

enum PaymentStatus {
  unpaid
  partially_paid
  paid
  refunded
  chargeback
}

model Payment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId String

  amount       Float
  currency     String        @default("USD")
  method       String? // card, bank_transfer, cash, other
  status       PaymentStatus @default(unpaid)
  exchangeRate Float?
  notes        String?

  @@index([bookingId])
}

// Records that a cardholder authorized a charge — never stores a full PAN/CVV.
// Only the last 4 digits, a signed declaration, and (optionally) a signature
// image are kept. If you ever need to actually process cards, use a PCI
// DSS-compliant processor's hosted fields/tokenization instead of touching
// raw card data in this app at all.
model CardAuthorization {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId String

  cardholderName   String
  cardLast4        String
  cardBrand        String?
  amount           Float
  currency         String    @default("USD")
  declarationText  String
  signatureDataUrl String?
  signedAt         DateTime?
  ipAddress        String?

  @@index([bookingId])
}

model Document {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?
  booking    Booking?  @relation(fields: [bookingId], references: [id])
  bookingId  String?

  type       String // passport | visa | ticket | invoice | receipt | insurance | authorization_form | hotel_voucher | cruise_confirmation | other
  fileUrl    String
  fileName   String?
  uploadedBy String?

  @@index([customerId])
  @@index([bookingId])
}

enum TaskStatus {
  pending
  in_progress
  done
  cancelled
}

model Task {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title       String
  description String?
  dueDate     DateTime?
  status      TaskStatus @default(pending)

  assignedAgent   Agent?  @relation(fields: [assignedAgentId], references: [id])
  assignedAgentId String?

  lead      Lead?    @relation(fields: [leadId], references: [id])
  leadId    String?
  booking   Booking? @relation(fields: [bookingId], references: [id])
  bookingId String?

  @@index([status])
  @@index([assignedAgentId])
}

enum CommChannel {
  call
  email
  whatsapp
  sms
  internal_note
}

model CommunicationLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  channel       CommChannel
  direction     String      @default("outbound") // inbound | outbound
  content       String
  attachmentUrl String?

  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?
  lead       Lead?     @relation(fields: [leadId], references: [id])
  leadId     String?
  booking    Booking?  @relation(fields: [bookingId], references: [id])
  bookingId  String?

  agent   Agent?  @relation(fields: [agentId], references: [id])
  agentId String?

  @@index([customerId])
  @@index([leadId])
  @@index([bookingId])
}

enum SupplierType {
  airline
  hotel
  cruise_line
  car_rental
  consolidator
  insurance
}

model Supplier {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  name            String
  type            SupplierType
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  commissionRate  Float?
  settlementTerms String?
  // Kept as an admin-only field, never rendered client-side. Treat as sensitive —
  // move to a dedicated secrets manager before storing anything beyond test keys.
  apiCredentials  Json?
  notes           String?
}

model ContactMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  name      String
  email     String
  subject   String?
  message   String
  handled   Boolean  @default(false)
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  email     String   @unique
  active    Boolean  @default(true)
}

model Testimonial {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  name      String
  location  String?
  quote     String
  rating    Int      @default(5)
  published Boolean  @default(false)
}

model FaqEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  category  String?
  question  String
  answer    String
  published Boolean  @default(true)
  sortOrder Int      @default(0)
}

model BlogPost {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  slug        String    @unique
  title       String
  excerpt     String?
  content     String
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
}

model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  actor     String? // admin email or "system"
  action    String
  entity    String?
  entityId  String?
  meta      Json?
}

// A click on a call/WhatsApp CTA, beaconed from the browser just before tel:/wa.me
// navigation. This is first-party call attribution: every row carries the page, the
// CTA placement, and the visitor's first/last-touch marketing params (utm_*, gclid,
// msclkid) captured by src/lib/attribution.ts. A call-tracking provider (CallRail,
// Twilio) later adds answered-call duration/recording on top; this table is what lets
// us join those calls back to campaign and keyword.
model CallClick {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  channel   String // 'call' | 'whatsapp'
  placement String // CTA location, e.g. 'cruise_hub_banner', 'lp_sticky_bar'
  page      String // pathname the click happened on
  vertical  Vertical?
  phone     String? // the business number displayed/dialed

  attribution Json? // { firstTouch: {...}, lastTouch: {...} } from src/lib/attribution.ts

  @@index([createdAt])
  @@index([channel])
  @@index([vertical])
}

// Package content model. Rich, mostly-static content (itinerary, reviews, FAQs,
// images, hotels, flight routes, JSON-LD-source fields — the full TravelPackage
// shape from src/lib/packages/types.ts) is generated by src/lib/packages/generator.ts
// and stored as `content` rather than fully normalized into join tables: it's
// composed once per (destination, duration) from curated destination facts, not
// hand-edited row-by-row, so normalizing it would add join overhead without a
// matching editing workflow. Fields that drive search/filter/listing pages ARE
// normalized as real columns so they can be indexed and queried directly.
//
// Pricing is deliberately NOT stored here — src/lib/packages/pricing.ts computes
// it on demand for any (origin market, traveler type, tier), the same shape a
// live flight/hotel-rate API integration would take.
model Destination {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  slug        String   @unique
  name        String
  country     String
  countryCode String
  region      String
  continent   String
  lat         Float
  lon         Float
  airportCode String
  airportName String
  currency    String
  categories  String[]
  facts       Json // full DestinationFacts payload — see src/lib/packages/types.ts

  packages Package[]

  @@index([country])
  @@index([region])
}

model Package {
  id              String      @id @default(cuid())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  slug            String      @unique
  destination     Destination @relation(fields: [destinationId], references: [id])
  destinationId   String
  destinationSlug String
  durationDays    Int
  durationNights  Int
  title           String
  metaTitle       String
  metaDescription String
  overview        String
  categories      String[]
  aiTags          String[]
  fromPriceUSD    Int // teaser price: solo, budget tier, US origin market — see pricing.ts
  ratingOverall   Float
  reviewCount     Int
  content         Json // full TravelPackage payload — see src/lib/packages/types.ts

  @@unique([destinationSlug, durationDays])
  @@index([destinationId])
  @@index([fromPriceUSD])
  @@index([durationDays])
}

// ---- Visa checker platform ----
// The base ruleset (199 passports x 199 destinations) ships with the app as a
// compiled dataset (src/data/visas/matrix.json, built by scripts/visas/build-matrix.mjs)
// so checks never depend on a DB round-trip for the common case. These tables hold
// only what must be mutable or accumulated at runtime: admin corrections to
// individual rules, and an analytics log of performed checks.

enum VisaCategory {
  visa_free
  visa_on_arrival
  e_visa
  eta
  visa_required
  no_admission
  home_country
}

// An admin-edited correction for one (passport, destination) pair. Overrides
// always win over the bundled matrix, and survive dataset refreshes.
model VisaRuleOverride {
  id              String       @id @default(cuid())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  passportCode    String // ISO2, uppercase
  destinationCode String // ISO2, uppercase
  category        VisaCategory
  allowedStayDays Int?
  notes           String? // rendered on the public result — keep it official-tone
  updatedBy       String?

  @@unique([passportCode, destinationCode])
  @@index([destinationCode])
}

// One row per visa check performed via the API or AI assistant — powers the
// admin analytics (top corridors, nationality trends). No PII is stored.
model VisaCheckLog {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  passportCode    String
  destinationCode String
  category        String?
  purpose         String?
  source          String? // 'api' | 'assistant'

  @@index([createdAt])
  @@index([passportCode])
  @@index([destinationCode])
}

// ---- Rail platform ----
// Bundled timetables (src/lib/trains/data) are the base truth; only mutable
// state lives here: per-train disruption/suspension notices set by the rail
// desk (always win, 60s in-memory cache) and search analytics.

model TrainServiceOverride {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trainSlug String   @unique // slug from the bundled services dataset
  status    String // 'running' | 'disrupted' | 'suspended'
  notes     String? // rendered on public pages — keep it official-tone
  updatedBy String?
}

// One row per corridor search via API, corridor page or AI assistant. No PII.
model TrainSearchLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  fromQuery String
  toQuery   String
  fromCode  String?
  toCode    String?
  results   Int      @default(0)
  source    String? // 'api' | 'corridor-page' | 'assistant'

  @@index([createdAt])
  @@index([fromCode, toCode])
}

// ---- Cruise & Car rental catalogs ----
// The generated cruise/car catalogs (10,641 + 17,165 records, ~850MB as JSON files)
// used to ship inside the Next.js serverless bundles via readFileSync, which forced
// Vercel to split routes into many functions and blew the Hobby-plan 12-function
// deployment cap. They live here instead: searchable columns for the list/filter
// pages, plus the full detail payload gzipped in `detail` (fits Neon's storage tier;
// decompressed + cached in-memory by src/lib/providers/{cruises,cars}.ts).

model CruiseCatalog {
  slug              String   @id
  title             String
  cruiseLineName    String
  shipName          String
  destination       String
  departurePortName String
  arrivalPortName   String
  durationNights    Int
  categories        String[]
  durationCats      String[] // e.g. "5-8 Nights" buckets, from filters.duration
  fromPriceUSD      Int
  ratingOverall     Float
  reviewCount       Int
  riverCruise       Boolean
  oceanCruise       Boolean
  adultsOnly        Boolean
  expedition        Boolean
  heroImage         Json // CruiseImageAsset
  filters           Json // Partial<CruiseSearchFilters> subset used by result cards
  searchText        String // lowercased haystack (title/line/ship/ports/tags) for q lookups
  detail            Bytes // gzipped full CruisePackage JSON

  @@index([destination])
  @@index([cruiseLineName])
  @@index([departurePortName])
  @@index([fromPriceUSD])
}

model CarCatalog {
  slug               String  @id
  title              String
  companyId          String
  companyName        String
  companyTier        String
  brand              String
  model              String
  year               Int
  category           String
  transmission       String
  fuelType           String
  seats              Int
  doors              Int
  luggage            Int
  locationName       String
  locationType       String
  city               String
  country            String
  countryCode        String
  fromPricePerDayUSD Int
  ratingOverall      Float
  reviewCount        Int
  ev                 Boolean
  hybrid             Boolean
  luxury             Boolean
  budget             Boolean
  airportPickup      Boolean
  unlimitedMileage   Boolean
  freeCancellation   Boolean
  petFriendly        Boolean
  oneWayAvailable    Boolean
  familyTravel       Boolean
  businessTravel     Boolean
  adventureTravel    Boolean
  heroImage          Json // CarImageAsset
  filters            Json // Partial<CarSearchFilters> subset used by result cards
  searchText         String // lowercased haystack (title/brand/model/company/location/tags)
  detail             Bytes // gzipped full CarListing JSON

  @@index([country])
  @@index([city])
  @@index([companyName])
  @@index([category])
  @@index([brand])
  @@index([fromPricePerDayUSD])
}
