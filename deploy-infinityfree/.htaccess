# Apache Rewrite Rules for React SPA + PHP API on InfinityFree
RewriteEngine On

# 1. CORS headers config (optional, but ensures security in PHP)
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
</IfModule>

# 2. Route all API requests starting with "/api/" directly to api.php
# This keeps your React codebase working on InfinityFree with ZERO changes!
RewriteCond %{REQUEST_URI} ^/api/ [NC]
RewriteRule ^api/(.*)$ api.php?route=$1 [QSA,L]

# 3. Route all other non-file and non-directory requests to index.html
# This allows React Router / Tab navigation to work perfectly on refreshes!
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.html [L]
