# Gemini API key for the AI Travel Planner (server-side only, never exposed to the client).
GEMINI_API_KEY="your-gemini-api-key"

# Postgres connection string (e.g. Neon) — same database used for dev and prod.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Simple shared-secret gate for /admin until proper multi-user auth is built.
ADMIN_PASSWORD="change-me"

# RapidAPI "Sky Scrapper" (unofficial Skyscanner scraper) — real-time flight
# search for lead generation. Leave RAPIDAPI_KEY unset to use the mock provider.
RAPIDAPI_KEY="your-rapidapi-key"
RAPIDAPI_HOST="sky-scrapper.p.rapidapi.com"

# RapidAPI "Booking.com15" — real-time hotel search, reuses RAPIDAPI_KEY above
# (subscribe to this API on the same RapidAPI account). Leave unset to use the
# mock hotel provider.
RAPIDAPI_HOTELS_HOST="booking-com15.p.rapidapi.com"

# Business contact info used for Call Now / WhatsApp CTAs sitewide.
NEXT_PUBLIC_BUSINESS_PHONE="+10000000000"
NEXT_PUBLIC_WHATSAPP_NUMBER="10000000000"
NEXT_PUBLIC_BUSINESS_EMAIL="bookings@example.com"

# Canonical site URL, used for sitemap/robots/OG/canonical tags.
NEXT_PUBLIC_SITE_URL="https://www.ticketing-info.org"

# Business state/country used in the TravelAgency Schema.org address (both optional —
# if unset, no address is published rather than publishing a placeholder).
NEXT_PUBLIC_BUSINESS_STATE="Wyoming"
NEXT_PUBLIC_BUSINESS_COUNTRY="US"

# Google Analytics 4 measurement ID (e.g. "G-XXXXXXXXXX"). Leave unset to skip loading GA
# entirely (no broken tag ships in dev/preview). See analytics.google.com to create one.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Google Search Console HTML-tag verification token (the value from the "content" attribute
# of the meta tag Search Console gives you, not the whole tag). Leave unset to skip.
NEXT_PUBLIC_GSC_VERIFICATION=""

# Google Ads conversion tracking (see GOOGLE-ADS-SETUP.md for exact steps). The ID is your
# Ads account's conversion ID, e.g. "AW-123456789". Each label is the per-action conversion
# label from a separate conversion action you create in Google Ads. All four are optional —
# conversion firing no-ops until they're set, same as the GA4 vars above.
NEXT_PUBLIC_GOOGLE_ADS_ID=""
NEXT_PUBLIC_GOOGLE_ADS_LABEL_LEAD=""
NEXT_PUBLIC_GOOGLE_ADS_LABEL_CALL=""
NEXT_PUBLIC_GOOGLE_ADS_LABEL_WHATSAPP=""
