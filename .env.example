# Gemini API key for the AI Travel Planner (server-side only, never exposed to the client).
GEMINI_API_KEY="your-gemini-api-key"

# Postgres connection string (e.g. Neon) — same database used for dev and prod.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Simple shared-secret gate for /admin until proper multi-user auth is built.
# Use a long, random passphrase in production.
ADMIN_PASSWORD="change-me"

# Application-level encryption key for sensitive customer PII (passport number,
# visa status) — 32 bytes, base64-encoded. Leave UNSET to disable encryption
# (fields are then stored as plaintext, same as before — safe default). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# After setting it for the first time, re-save existing customers once so their
# legacy plaintext rows get encrypted. Rotating this key makes existing
# ciphertext unreadable, so store it durably (Vercel env + a secrets manager).
PII_ENCRYPTION_KEY=""

# RapidAPI "Sky Scrapper" (unofficial Skyscanner scraper) — real-time flight
# search for lead generation. Leave RAPIDAPI_KEY unset to use the mock provider.
RAPIDAPI_KEY="your-rapidapi-key"
RAPIDAPI_HOST="sky-scrapper.p.rapidapi.com"

# RapidAPI "Booking.com15" — real-time hotel search, reuses RAPIDAPI_KEY above
# (subscribe to this API on the same RapidAPI account). Leave unset to use the
# mock hotel provider.
RAPIDAPI_HOTELS_HOST="booking-com15.p.rapidapi.com"

# Business contact info used for Call Now / WhatsApp CTAs sitewide.
NEXT_PUBLIC_BUSINESS_PHONE="+10000000000"
NEXT_PUBLIC_WHATSAPP_NUMBER="10000000000"
NEXT_PUBLIC_BUSINESS_EMAIL="bookings@example.com"

# Instant new-lead alerts (server-side). When set, every booking enquiry
# (flight/hotel/cruise/package/etc.) POSTs a Slack-formatted message to this
# webhook the moment it's submitted, so a consultant can respond fast instead of
# watching /admin/leads. Create a Slack "Incoming Webhook"
# (https://api.slack.com/messaging/webhooks) and paste its URL here — also works
# with Mattermost, Google Chat, or a Zapier/Make catch-hook. Leave unset to
# disable (leads are still saved to the admin panel regardless).
LEAD_NOTIFY_WEBHOOK_URL=""

# Canonical site URL, used for sitemap/robots/OG/canonical tags.
NEXT_PUBLIC_SITE_URL="https://www.ticketing-info.org"

# Business state/country used in the TravelAgency Schema.org address (both optional —
# if unset, no address is published rather than publishing a placeholder).
NEXT_PUBLIC_BUSINESS_STATE="Wyoming"
NEXT_PUBLIC_BUSINESS_COUNTRY="US"

# Google Analytics 4 measurement ID (e.g. "G-XXXXXXXXXX"). Leave unset to skip loading GA
# entirely (no broken tag ships in dev/preview). See analytics.google.com to create one.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Google Search Console HTML-tag verification token (the value from the "content" attribute
# of the meta tag Search Console gives you, not the whole tag). Leave unset to skip.
NEXT_PUBLIC_GSC_VERIFICATION=""

# Google Ads conversion tracking (see GOOGLE-ADS-SETUP.md for exact steps). The ID is your
# Ads account's conversion ID, e.g. "AW-123456789". Each label is the per-action conversion
# label from a separate conversion action you create in Google Ads. All four are optional —
# conversion firing no-ops until they're set, same as the GA4 vars above.
NEXT_PUBLIC_GOOGLE_ADS_ID=""
NEXT_PUBLIC_GOOGLE_ADS_LABEL_LEAD=""
NEXT_PUBLIC_GOOGLE_ADS_LABEL_CALL=""
NEXT_PUBLIC_GOOGLE_ADS_LABEL_WHATSAPP=""

# ── Marketing Intelligence dashboard (/admin/marketing) — all read-only reporting APIs ──
# See GOOGLE-MARKETING-API-SETUP.md for step-by-step instructions on obtaining every value.
# Each source is independently optional: the dashboard shows a "not connected" card for
# any source whose vars are unset instead of breaking.

# GCP service account key JSON, base64-encoded in one line (used by both GA4 and Search
# Console; server-side only). Encode with:  base64 -w0 service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=""

# GA4 property ID — the numeric ID from GA4 Admin → Property Settings (e.g. "123456789",
# NOT the G-XXXXXXXX measurement ID). The service account email must be added as a Viewer
# on the property.
GA4_PROPERTY_ID=""

# Search Console property exactly as registered — either "sc-domain:ticketing-info.org"
# (domain property) or "https://www.ticketing-info.org/" (URL-prefix property). The service
# account email must be added as a user on the property.
GSC_SITE_URL=""

# Google Ads API (read-only reporting). Requires a developer token (Ads UI → Tools → API
# Center), an OAuth desktop client, and a one-time refresh-token generation step — all
# covered in GOOGLE-MARKETING-API-SETUP.md.
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""
GOOGLE_ADS_REFRESH_TOKEN=""
# Your Ads account's customer ID, digits only or with dashes (e.g. "123-456-7890").
GOOGLE_ADS_CUSTOMER_ID=""
# Only needed if the account above is accessed through a manager (MCC) account.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=""
